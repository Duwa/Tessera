# Copy to .env and fill in values

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=tessera
POSTGRES_PASSWORD=tessera
POSTGRES_DB=tessera

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for Agent Factory /select and /generate endpoints
ANTHROPIC_API_KEY=sk-ant-...

# ── Azure ─────────────────────────────────────────────────────────────────────
# Required for Deployment service (ACI + AKS). Leave blank to use simulate mode.
#
# To create a service principal:
#   az ad sp create-for-rbac --name tessera-deploy --role contributor \
#     --scopes /subscriptions/<subscription-id>
#
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Resource names (will be created if they don't exist)
AZURE_RESOURCE_GROUP=tessera-rg
AZURE_LOCATION=eastus
AZURE_ACR_NAME=tesseraacr          # Must be globally unique
AZURE_AKS_CLUSTER=tessera-aks
